<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!--
        Exercise 1 & 2: Bean definitions for Library Management Application
        - bookRepository bean is defined first (no dependencies)
        - bookService bean is defined next, with bookRepository injected via setter (DI)
    -->

    <!-- Bean definition for BookRepository -->
    <bean id="bookRepository" class="com.library.repository.BookRepository"/>

    <!-- Bean definition for BookService; BookRepository is injected via setter DI -->
    <bean id="bookService" class="com.library.service.BookService">
        <property name="bookRepository" ref="bookRepository"/>
    </bean>

</beans>
