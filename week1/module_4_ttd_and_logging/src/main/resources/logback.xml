<configuration>

    <!--
        logback.xml — Logback Configuration
        Configures log output format and level for the LoggingExample application.
        Place this file in src/main/resources so Logback finds it on the classpath.
    -->

    <!-- Console Appender: writes log output to System.out -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!--
                Pattern breakdown:
                  %d{HH:mm:ss.SSS}  — timestamp
                  %-5level           — log level, left-padded to 5 chars
                  %logger{36}        — logger name (class), max 36 chars
                  %msg               — the log message
                  %n                 — newline
            -->
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- File Appender: writes logs to a rolling file -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Roll over daily; keep 7 days of history -->
            <fileNamePattern>logs/application.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!--
        Root logger level: TRACE — captures all levels for demonstration.
        In production, typically set to INFO or WARN.
    -->
    <root level="TRACE">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>

</configuration>
